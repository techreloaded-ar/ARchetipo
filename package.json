{
  "scripts": {
    "test": "npm run test:cli",
    "build:cli": "cd cli && go run github.com/goreleaser/goreleaser/v2@v2.15.4 release --snapshot --clean",
    "build:cli:dev": "node ./scripts/build-cli-dev.mjs",
    "install:dev": "node ./scripts/install-dev.mjs",
    "uninstall:dev": "node ./scripts/uninstall-dev.mjs",
    "release:cli": "cd cli && go run github.com/goreleaser/goreleaser/v2@v2.15.4 release --clean",
    "build:npm": "node ./scripts/build-npm.mjs",
    "publish:npm": "node ./scripts/publish-npm.mjs",
    "test:cli": "cd cli && go test ./...",
    "test:e2e": "node ./test/e2e/run.mjs",
    "test:wiki-benchmark": "node ./test/benchmark/wiki/run.mjs",
    "test:wiki-benchmark:unit": "node --test ./test/benchmark/wiki/run.test.mjs",
    "test:view-delete-smoke": "node ./test/e2e/delete-story-view-smoke.mjs",
    "test:wiki-smoke": "node ./test/e2e/wiki-smoke.mjs"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
